{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XClaw",
  "version": "1.4.1",
  "identifier": "com.xindieshu.clawdeploy",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "XClaw",
        "label": "main",
        "width": 1440,
        "height": 960,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "center": true
      },
      {
        "title": "XClaw",
        "label": "tray-popup",
        "url": "#/tray-popup",
        "width": 320,
        "height": 440,
        "decorations": false,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "focusable": true,
        "hiddenTitle": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
